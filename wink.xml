<file path="template.html">
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{.Config.Title}}</title>
        <style>{{.CSS}}</style>
      </head>
      <body>
        {{template "sections" .Config.Sections}}
      </body>
    </html>

    {{define "sections"}}
    {{range .}}
    <section{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>
      {{range .Headings}}
      {{template "heading" .}}
      {{end}}
      {{if .Content}}
      <p>{{.Content}}</p>
      {{end}}
      {{range .Links}}
      {{template "link" .}}
      {{end}}
      {{if .Sections}}
      {{template "sections" .Sections}}
      {{end}}
    </section>
    {{end}}
    {{end}}

    {{define "heading"}}
    {{if eq .Level 1}}<h1{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h1>{{end}}
    {{if eq .Level 2}}<h2{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h2>{{end}}
    {{if eq .Level 3}}<h3{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h3>{{end}}
    {{if eq .Level 4}}<h4{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h4>{{end}}
    {{if eq .Level 5}}<h5{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h5>{{end}}
    {{if eq .Level 6}}<h6{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</h6>{{end}}
    {{end}}

    {{define "link"}}
    <a href="{{.Href}}"{{if .Class}} class="{{.Class}}"{{end}}{{if .ID}} id="{{.ID}}"{{end}}>{{.Content}}</a>
    {{end}}
</file>

