<file path="main.go">
package main

import (
	"html/template"
	"log"
	"os"

	"gopkg.in/yaml.v3"
)

type Link struct {
	Href    string `yaml:"href"`
	Content string `yaml:"content"`
	Class   string `yaml:"class,omitempty"`
	ID      string `yaml:"id,omitempty"`
}

type Heading struct {
	Level   int    `yaml:"level"`
	Content string `yaml:"content"`
	Class   string `yaml:"class,omitempty"`
	ID      string `yaml:"id,omitempty"`
}

type Section struct {
	Content  string    `yaml:"content,omitempty"`
	Class    string    `yaml:"class,omitempty"`
	ID       string    `yaml:"id,omitempty"`
	Headings []Heading `yaml:"headings,omitempty"`
	Links    []Link    `yaml:"links,omitempty"`
	Sections []Section `yaml:"sections,omitempty"`
}

type Config struct {
	Title    string    `yaml:"title"`
	Sections []Section `yaml:"sections"`
}

type PageData struct {
	Config Config
	CSS    template.CSS
}

func main() {
	configData, err := os.ReadFile("config.yaml")
	if err != nil {
		log.Fatalf("Error reading config.yaml: %v", err)
	}

	var config Config
	err = yaml.Unmarshal(configData, &config)
	if err != nil {
		log.Fatalf("Error parsing config.yaml: %v", err)
	}

	cssData, err := os.ReadFile("styles.css")
	if err != nil {
		log.Fatalf("Error reading styles.css: %v", err)
	}

	tmplData, err := os.ReadFile("template.html")
	if err != nil {
		log.Fatalf("Error reading template.html: %v", err)
	}

	tmpl, err := template.New("page").Parse(string(tmplData))
	if err != nil {
		log.Fatalf("Error parsing template: %v", err)
	}

	outFile, err := os.Create("output.html")
	if err != nil {
		log.Fatalf("Error creating output file: %v", err)
	}
	defer outFile.Close()

	pageData := PageData{
		Config: config,
		CSS:    template.CSS(cssData),
	}

	err = tmpl.Execute(outFile, pageData)
	if err != nil {
		log.Fatalf("Error executing template: %v", err)
	}

	log.Println("Successfully generated output.html")
}
